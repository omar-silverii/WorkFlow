          "label": "Cargar nota de crédito",
          "params": {
            "docTipoCodigo": "NOTA_CREDITO_ELECTRONICA_AR"
          }
        },
        {
          "type": "control.if",
          "label": "Total mayor a 200000",
          "params": {
            "field": "biz.notaCredito.total",
            "op": ">",
            "value": "200000"
          }
        },
        {
          "type": "human.task",
          "label": "Aprobación Dirección",
          "params": {
            "rol": "DIR_GENERAL"
          }
        },
        {
