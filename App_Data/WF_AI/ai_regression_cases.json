  {
    "id": "B_NOTIFY_POR_RAMA",
    "name": "Frase B - Notificaciones por rama",
    "description": "Valida total > 200000, tarea DIR_GENERAL, notify a COMPRAS en APTO, logger+notify en NO APTO y logger Info en caso contrario.",
    "phrase": "Cargar una nota de crédito. Si el total supera los 200000 pesos, enviarla a DIR_GENERAL para aprobar. Si Dirección la aprueba, notificar a COMPRAS indicando que la nota de crédito fue aprobada por Dirección y finalizar. Si Dirección la rechaza, registrar una advertencia indicando que fue rechazada por Dirección, notificar a COMPRAS y finalizar. Caso contrario, registrar un evento informativo indicando que no requiere aprobación de Dirección y finalizar.",
    "enabled": true,
    "expected": {
      "validationOk": true,
      "semanticOk": true,
      "semanticWarningsEmpty": true,
      "semanticErrorsEmpty": true,
      "nodes": [
        {
          "type": "doc.load",
          "label": "Cargar nota de crédito",
          "params": {
            "docTipoCodigo": "NOTA_CREDITO_ELECTRONICA_AR"
          }
        },
        {
          "type": "control.if",
          "label": "Total mayor a 200000",
          "params": {
            "field": "biz.notaCredito.total",
            "op": ">",
            "value": "200000"
          }
        },
        {
          "type": "human.task",
          "label": "Aprobación Dirección",
          "params": {
            "rol": "DIR_GENERAL"
          }
        },
        {
          "type": "util.logger",
          "label": "Registrar evento sin aprobación de Dirección",
          "params": {
            "level": "Info",
            "message": "no requiere aprobación de Dirección"
          }
        },
        {
          "type": "control.if",
          "label": "Resultado de DIR_GENERAL aprobado",
          "params": {
            "field": "wf.tarea.resultado",
            "op": "==",
            "value": "apto"
          }
        },
        {
          "type": "util.notify",
          "label": "Notificar aprobación de DIR_GENERAL a COMPRAS",
          "params": {
            "rolDestino": "COMPRAS",
            "mensaje": "la nota de crédito fue aprobada por Dirección"
          }
        },
        {
          "type": "util.logger",
          "label": "Registrar rechazo de DIR_GENERAL",
          "params": {
            "level": "Warn",
            "message": "fue rechazada por Dirección"
          }
        },
        {
          "type": "util.notify",
          "label": "Notificar rechazo de DIR_GENERAL a COMPRAS",
          "params": {
            "rolDestino": "COMPRAS",
            "mensaje": "fue rechazada por Dirección"
          }
        },
        {
          "type": "util.end",
          "label": "Fin",
          "params": {}
        }
      ],
