          "condition": "SI"
        },
        {
          "from": "Total mayor a 200000",
          "to": "Registrar evento sin aprobación de Dirección",
          "condition": "NO"
        },
        {
          "from": "Aprobación Dirección",
          "to": "Resultado de DIR_GENERAL aprobado"
        },
        {
          "from": "Resultado de DIR_GENERAL aprobado",
          "to": "Notificar aprobación de DIR_GENERAL a COMPRAS",
          "condition": "SI"
        },
        {
